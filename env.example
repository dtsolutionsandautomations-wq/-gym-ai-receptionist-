# ── ANTHROPIC (Claude AI) ────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── ELEVENLABS (Human-like Voice) ───────────────────────────
# Get from: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ── ELEVENLABS VOICE ID ──────────────────────────────────────
# Recommended voices:
#   Aria (female, warm):     EXAVITQu4vr4xnSDxMaL  ← default
#   Rachel (female, clear):  21m00Tcm4TlvDq8ikWAM
#   Josh (male, friendly):   TxGEqnHWrfWFTfGW9XjX
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── EXOTEL (Indian +91 numbers — replaces Twilio) ────────────
# Sign up FREE at https://exotel.com (15-day trial, ₹1000 free usage)
# Find these in: Exotel Dashboard → Settings → API Settings
EXOTEL_SID=your-exotel-account-sid
EXOTEL_KEY=your-exotel-api-key
EXOTEL_TOKEN=your-exotel-api-token
EXOTEL_SUBDOMAIN=api.exotel.com

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
# Your deployed URL — Railway or Render gives you this after deploy
# Example: https://gym-ai-receptionist.up.railway.app
BASE_URL=https://your-app-name.up.railway.app
